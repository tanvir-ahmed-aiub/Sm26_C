*@

@{
    bool CheckGender(string gn)
    {
        if (Model.Gender == gn) return true;
        return false;
    }

    bool CheckProfession(string pef)
    {

        if (Model.Profession == pef) return true;
        return false;
    }
    bool CheckHobbies(string hb)
    {
        if (Model.Hobbies != null)
        {

            foreach (var item in Model.Hobbies)
            {
                if (item == hb) return true;
            }
        }
        return false;

    }
}


@Html.ValidationSummary()

<form action="" method="post">
    <input  type="text" class="form-control" value="@Model.Name" name="Name" placeholder="Name" />
    <span class="text-danger">@Html.ValidationMessage("Name")</span>
    <input  type="text" class="form-control" value="@Model.Uname" name="Uname" placeholder="Username" />
    <span class="text-danger">@Html.ValidationMessage("Uname")</span>
    <input  type="text" class="form-control" value="@Model.Email" name="Email" placeholder="Email" />
    <span class="text-danger">@Html.ValidationMessage("Email")</span>
    Gender: <input type="radio" checked="@CheckGender("Male")" name="Gender" value="Male" />Male
    <input type="radio" checked="@CheckGender("Female")" name="Gender" value="Female" />Female <br />

    Profession: 
    <select name="Profession">
        <option disabled selected>---select---</option>
        <option selected="@CheckProfession("Student")">Student</option>
        <option selected="@CheckProfession("Business")">Business</option>
        <option selected="@CheckProfession("Both")">Both</option>
    </select>
    <br />
    Hobbies: 
    <input type="checkbox" checked="@CheckHobbies("Sports")" name="Hobbies[]" value="Sports" /> Sports
    <input type="checkbox" checked="@CheckHobbies("Games")" name="Hobbies[]" value="Games" /> Games
    <input type="checkbox" checked="@CheckHobbies("Travelling")" name="Hobbies[]" value="Travelling" /> Travelling

    <input type="text" name="Roll" value="@Model.Roll" class="form-control" placeholder="Roll" />
    <input type="submit" value="Register" class="btn btn-primary" />
</form>