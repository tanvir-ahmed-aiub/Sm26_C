@{
}
<h1>Student Info</h1>

<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th></th>
    </tr>
    @for (int i = 0; i < ViewBag.Students.Length; i++)
    {
        <tr>
            <td>@ViewBag.Students[i].Id</td>
            <td>@ViewBag.Students[i].Name</td>
            <td><a href="/students/details/@ViewBag.Students[i].Name/@ViewBag.Students[i].Id" class="btn btn-primary">Details</a></td>
        </tr>
        
    }
    
    
</table>